# Task Verifier — Environment Variables
# Copy to .env.local and fill in your values

# Required (at least one): Deployed GenLayer contract addresses
NEXT_PUBLIC_VERIFIER_CONTRACT=0x_YOUR_BRADBURY_CONTRACT_ADDRESS
NEXT_PUBLIC_VERIFIER_CONTRACT_STUDIO=0x_YOUR_STUDIO_CONTRACT_ADDRESS

# Liked-Post Verifier (separate contract for Task 3)
NEXT_PUBLIC_LIKED_VERIFIER_CONTRACT=0x_YOUR_BRADBURY_LIKED_CONTRACT_ADDRESS
NEXT_PUBLIC_LIKED_VERIFIER_CONTRACT_STUDIO=0x_YOUR_STUDIO_LIKED_CONTRACT_ADDRESS

# Profile Verifier (X handle verification via tweet + screenshot, Task 2)
NEXT_PUBLIC_PROFILE_VERIFIER_CONTRACT=0xeE77ca5d63d05c54317dDC0fdcDAa14af3cC113a
NEXT_PUBLIC_PROFILE_VERIFIER_CONTRACT_STUDIO=0x1F714BD20c6A669Ed22F5df421959eB5D43910C1

# Optional: WalletConnect Cloud project ID (for QR code / mobile wallet support)
# Get one at: https://cloud.walletconnect.com
# If not set, only browser extension wallets (MetaMask, etc.) will be available.
# NEXT_PUBLIC_WALLETCONNECT_ID=
