1|# Task Verifier — Environment Variables
     2|# Copy to .env.local and fill in your values
     3|
     4|# Required (at least one): Deployed GenLayer contract addresses
     5|NEXT_PUBLIC_VERIFIER_CONTRACT=0x_YOUR_BRADBURY_CONTRACT_ADDRESS
     6|NEXT_PUBLIC_VERIFIER_CONTRACT_STUDIO=0x_YOUR_STUDIO_CONTRACT_ADDRESS
     7|
     8|# Liked-Post Verifier (separate contract for Task 2)
     9|NEXT_PUBLIC_LIKED_VERIFIER_CONTRACT=0x_YOUR_BRADBURY_LIKED_CONTRACT_ADDRESS
    10|NEXT_PUBLIC_LIKED_VERIFIER_CONTRACT_STUDIO=0x_YOUR_STUDIO_LIKED_CONTRACT_ADDRESS
    11|
    12|# Profile Verifier (X handle verification via tweet + screenshot)
NEXT_PUBLIC_PROFILE_VERIFIER_CONTRACT=0xb2353301C4302e50D22cA7eebd0C0d920271596e
NEXT_PUBLIC_PROFILE_VERIFIER_CONTRACT_STUDIO=0xefB55478Cb25B3C534fbD7a656f17918E6E0E6f5
    15|
    16|# Optional: WalletConnect Cloud project ID (for QR code / mobile wallet support)
    17|# Get one at: https://cloud.walletconnect.com
    18|# If not set, only browser extension wallets (MetaMask, etc.) will be available.
    19|# NEXT_PUBLIC_WALLETCONNECT_ID=
    20|
